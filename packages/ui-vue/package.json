{
  "name": "@rtcstack/ui-vue",
  "version": "1.0.1",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./styles.css": "./dist/styles.css"
  },
  "repository": { "type": "git", "url": "https://github.com/radioBros/RTCstack" },
  "homepage": "https://github.com/radioBros/RTCstack",
  "bugs": { "url": "https://github.com/radioBros/RTCstack/issues" },
  "files": ["dist", "README.md"],
  "publishConfig": { "access": "public" },
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "prepublishOnly": "pnpm run build",
    "storybook": "storybook dev -p 6007",
    "build-storybook": "storybook build",
    "test": "vitest run",
    "lint": "eslint src --ext .ts,.vue",
    "typecheck": "vue-tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@rtcstack/sdk": "workspace:*"
  },
  "peerDependencies": {
    "livekit-client": ">=2.0.0",
    "vue": ">=3.4.0"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "^8.1.0",
    "@storybook/addon-essentials": "^8.1.0",
    "@storybook/vue3": "^8.1.0",
    "@storybook/vue3-vite": "^8.1.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "livekit-client": "^2.5.0",
    "storybook": "^8.1.0",
    "typescript": "^5.4.0",
    "vite": "^5.2.0",
    "vite-plugin-dts": "^3.9.0",
    "vitest": "^1.5.0",
    "vue": "^3.4.0",
    "vue-tsc": "^2.0.0"
  }
}
