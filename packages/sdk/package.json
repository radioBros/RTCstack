{
  "name": "@rtcstack/sdk",
  "version": "1.0.1",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./mock": {
      "import": "./dist/mock.js",
      "require": "./dist/mock.cjs",
      "types": "./dist/mock.d.ts"
    }
  },
  "repository": { "type": "git", "url": "https://github.com/radioBros/RTCstack" },
  "homepage": "https://github.com/radioBros/RTCstack",
  "bugs": { "url": "https://github.com/radioBros/RTCstack/issues" },
  "files": ["dist", "README.md"],
  "publishConfig": { "access": "public" },
  "scripts": {
    "build": "vite build && tsc --emitDeclarationOnly",
    "dev": "vite build --watch",
    "prepublishOnly": "pnpm run build",
    "test": "vitest run",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "size": "size-limit",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "livekit-client": ">=2.0.0"
  },
  "devDependencies": {
    "@size-limit/preset-small-lib": "^11.1.0",
    "@types/node": "^20.12.0",
    "livekit-client": "^2.5.0",
    "size-limit": "^11.1.0",
    "typescript": "^5.4.0",
    "vite": "^5.2.0",
    "vite-plugin-dts": "^3.9.0",
    "vitest": "^1.5.0"
  },
  "size-limit": [
    {
      "path": "dist/index.js",
      "limit": "80 kB",
      "gzip": true
    }
  ]
}
