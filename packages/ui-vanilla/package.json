{
  "name": "@rtcstack/ui-vanilla",
  "version": "1.0.1",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "repository": { "type": "git", "url": "https://github.com/radioBros/RTCstack" },
  "homepage": "https://github.com/radioBros/RTCstack",
  "bugs": { "url": "https://github.com/radioBros/RTCstack/issues" },
  "files": ["dist", "README.md"],
  "publishConfig": { "access": "public" },
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "prepublishOnly": "pnpm run build",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@rtcstack/sdk": "workspace:*"
  },
  "peerDependencies": {
    "livekit-client": ">=2.0.0"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "vite": "^5.2.0",
    "vite-plugin-dts": "^3.9.0",
    "vitest": "^1.5.0"
  }
}
